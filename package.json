{
  "name": "quantium",
  "version": "1.0.0",
  "description": "Quantium Internet & Web of Things - A next-generation distributed network protocol",
  "main": "bin/cli.js",
  "bin": {
    "quantium": "./bin/cli.js"
  },
  "scripts": {
    "start": "node bin/cli.js",
